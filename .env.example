# Opcional se voce migrar para Vite no futuro.
# Neste projeto estatico, copie config/firebase-config.example.js para config/firebase-config.js
# e preencha os valores publicos do app web do Firebase.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Variáveis secretas da função /api/notifications na Vercel.
# Nunca coloque os valores verdadeiros em arquivos enviados ao GitHub.
FIREBASE_PROJECT_ID=igreja-zuriel
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
